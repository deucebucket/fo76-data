<?xml version="1.0" encoding="utf-8" ?>
<Automatron xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	
	<!--
	
	Enemy Data example:
	
	<Enemy> ............................................. Enemy tag
		  <Id>6</Id> .................................... Enemy yype (1: Grunt, 2: Electrode, 3: Spawner, 4: Enforcer spawned, 5: Hulk indestructible, 6: Brain)
		  <Name>Brain</Name> ............................ Enemy name
		  <LinkageId>EnemyType5</LinkageId> ............. Enemy visual link to Flash
		  <Points displayOnScreen="true">2000</Points> .. Points when killing this enemy (can be displayed on screen when killed)
		  <MustBeKilled>true</MustBeKilled> ............. Mandatory to kill to reach next Level
		  <Path> ........................................ (optional tag to define enemy movement)
			  <Id>1</Id> ................................ Enemy Path type (1: FOLLOWER_PATH, 2: RANDOM_ALL_DIR_PATH, 3: RANDOM_ALL_DIR_WITH_AGGRO_PATH, 4: RANDOM_4_DIR_PATH, 5: RANDOM_8_DIR_PATH)
			  <SpeedMin>2</SpeedMin> .................... Enemy minimum speed
			  <SpeedMax>3</SpeedMax> .................... Enemy maximum speed
			  <SpeedMod>0.1</SpeedMod> .................. Enemy speed modifier (applied at each round)
			  <AllowStop>false</AllowStop> .............. true if the Enemy can stop moving sometimes
			  <ChangeDirectionAfterStopDelay>0.5</ChangeDirectionAfterStopDelay> ... Delay before changing direction after stopping (in seconds)(only used if <allowStop>true</allowStop>)
			  <ChangeDirectionDelayMin>3</ChangeDirectionDelayMin> ................. Minimum delay before changing direction (in seconds)
			  <ChangeDirectionDelayMax>5</ChangeDirectionDelayMax> ................. Maximum delay before changing direction (in seconds)
			  <AggroRadius>200</AggroRadius> ............ Below this radius, the enemy track the target instead of moving randomly (in pixels)
			  <HuntHumans>true</HuntHumans> ............. true if the Enemy can hunt humans
		  </Path>
		  <Bullet> ...................................... (optional tag to define enemy bullets properties)
			  <LinkageId>EnemyBulletMc</LinkageId> ...... Bullet visual link to Flash
			  <SpeedMin>8</Speed> ....................... Bullet minimum speed
			  <SpeedMax>10</Speed> ...................... Bullet maximum speed
			  <SpeedMod>0.1</Speed> ..................... Bullet speed modifier (applied at each round)
			  <Points>25</Points> ....................... Points when destroying this bullet
			  <FireDelayMin>4</FireDelayMin> ............ Minimum delay before firing (in seconds)
			  <FireDelayMax>10</FireDelayMax> ........... Maximum delay before firing (in seconds)
			  <FireDelayOffsetMax>2</FireDelayOffsetMax>  Maximum offset to reduce FireDelayMin
			  <FireDelayOffsetMod>0.5</FireDelayOffsetMod> Fire delay offset modifier (applied at each round)
			  <ReactionDelay>8</ReactionDelay> .......... Delay before changing direction (in frames)
			  <AnticipationChances>80</AnticipationChances> ... Probability to anticipate the target position (in %)
		  </Bullet>
		  <SpawnEnemy> .................................. (optional tag to define Enemy to spawn) Exact same thing than Enemy tag
			  <Id>4</Id>
			  <Name>Enforcer</Name>
			  <LinkageId>EnemyType3</LinkageId>
			  <Points>500</Points>
			  <MustBeKilled>true</MustBeKilled>
			  <Path>
				  <Id>1</Id>
				  <Speed>1</Speed>
				  <AllowStop>false</AllowStop>
			  </Path>
			  <SpawnDelayMin>5</SpawnDelayMin> .......... Minimum delay before spawning (in seconds)
			  <SpawnDelayMax>10</SpawnDelayMax> ......... Maximum delay before spawning (in seconds)
			  <SpawnDelayOffsetMax>3</SpawnDelayOffsetMax> ..... Maximum offset to reduce SpawnDelayMin
			  <SpawnDelayOffsetMod>0.6</SpawnDelayOffsetMod> ... Spawn delay offset modifier (applied at each round)
		  </SpawnEnemy>
	 </Enemy>
	 
	-->
	
	<Enemies>
	  <Enemy>
		  <Id>Grunt</Id>
		  <Name>Grunt</Name>
		  <LinkageId>EnemyType2</LinkageId>
		  <Points>200</Points>
		  <MustBeKilled>true</MustBeKilled>
		  <Path>
			  <Id>1</Id>
			  <SpeedMin>1.75</SpeedMin>
			  <SpeedMax>2.75</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <AllowStop>false</AllowStop>
		  </Path>
	  </Enemy>
	  <Enemy>
		  <Id>Mine</Id>
		  <Name>Electrode</Name>
		  <LinkageId>EnemyType1</LinkageId>
	  </Enemy>
	  <Enemy>
		  <Id>Spawner</Id>
		  <Name>Spheroid</Name>
		  <LinkageId>EnemyType5</LinkageId>
		  <Points displayOnScreen="true">1000</Points>
		  <MustBeKilled>true</MustBeKilled>
		  <Path>
			  <Id>5</Id>
			  <SpeedMin>4.5</SpeedMin>
			  <SpeedMax>5.5</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <AllowStop>false</AllowStop>
			  <ChangeDirectionDelayMin>3</ChangeDirectionDelayMin>
			  <ChangeDirectionDelayMax>5</ChangeDirectionDelayMax>
		  </Path>
		  <Spawn>
			  <Id>Spawned</Id>
			  <DelayMin>4</DelayMin>
			  <DelayMax>8</DelayMax>
			  <DelayOffsetMax>3</DelayOffsetMax>
			  <DelayOffsetMod>0.6</DelayOffsetMod>
		  </Spawn>
	  </Enemy>
	  <Enemy>
		  <Id>Spawned</Id>
		  <Name>Enforcer</Name>
		  <LinkageId>EnemyType3</LinkageId>
		  <Points>250</Points>
		  <MustBeKilled>true</MustBeKilled>
		  <Path>
			  <Id>3</Id>
			  <SpeedMin>2</SpeedMin>
			  <SpeedMax>3</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <AllowStop>false</AllowStop>
			  <ChangeDirectionDelayMin>3</ChangeDirectionDelayMin>
			  <ChangeDirectionDelayMax>5</ChangeDirectionDelayMax>
			  <AggroRadius>150</AggroRadius>
		  </Path>
		  <Bullet>
			  <LinkageId>EnforcerBulletMc</LinkageId>
			  <SpeedMin>8</SpeedMin>
			  <SpeedMax>10</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <Points>10</Points>
			  <FireDelayMin>2.5</FireDelayMin>
			  <FireDelayMax>4.5</FireDelayMax>
			  <FireDelayOffsetMax>1</FireDelayOffsetMax>
			  <FireDelayOffsetMod>0.2</FireDelayOffsetMod>
			  <AnticipationChances>80</AnticipationChances>
		  </Bullet>
	  </Enemy>
	  <Enemy>
		  <Id>Indestructible</Id>
		  <Name>Hulk</Name>
		  <LinkageId>EnemyType4</LinkageId>
		  <Path>
			  <Id>4</Id>
			  <SpeedMin>2</SpeedMin>
			  <SpeedMax>3</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <AllowStop>true</AllowStop>
			  <ChangeDirectionAfterStopDelay>0.5</ChangeDirectionAfterStopDelay>
			  <ChangeDirectionDelayMin>2</ChangeDirectionDelayMin>
			  <ChangeDirectionDelayMax>3</ChangeDirectionDelayMax>
		  </Path>
	  </Enemy>
	  <Enemy>
		  <Id>Brain</Id>
		  <Name>Brain</Name>
		  <LinkageId>EnemyType0</LinkageId>
		  <Points>500</Points>
		  <MustBeKilled>true</MustBeKilled>
		  <Path>
			  <Id>3</Id>
			  <SpeedMin>0.5</SpeedMin>
			  <SpeedMax>1.5</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <AllowStop>false</AllowStop>
			  <ChangeDirectionDelayMin>3</ChangeDirectionDelayMin>
			  <ChangeDirectionDelayMax>5</ChangeDirectionDelayMax>
			  <HuntHumans>true</HuntHumans>
			  <AggroRadius>75</AggroRadius>
		  </Path>
		  <Bullet>
			  <LinkageId>BrainBulletMc</LinkageId>
			  <SpeedMin>4.5</SpeedMin>
			  <SpeedMax>5.5</SpeedMax>
			  <SpeedMod>0.1</SpeedMod>
			  <Points>25</Points>
			  <FireDelayMin>6</FireDelayMin>
			  <FireDelayMax>10</FireDelayMax>
			  <FireDelayOffsetMax>2</FireDelayOffsetMax>
			  <FireDelayOffsetMod>0.5</FireDelayOffsetMod>
			  <ReactionDelay>8</ReactionDelay>
		  </Bullet>
	  </Enemy>
  </Enemies>
</Automatron>